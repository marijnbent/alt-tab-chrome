{
  "manifest_version": 3,
  "name": "Tab Switcher",
  "version": "1.0.0",
  "description": "Alt+Tab style tab switcher for Chrome",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "all_frames": false,
    "run_at": "document_idle"
  }],
  "commands": {
    "cycle-tabs": {
      "suggested_key": {
        "default": "Alt+Tab",
        "mac": "Alt+Tab"
      },
      "description": "Cycle through tabs"
    },
    "cycle-tabs-back": {
      "suggested_key": {
        "default": "Alt+Shift+Tab",
        "mac": "Alt+Shift+Tab"
      },
      "description": "Cycle through tabs (backwards)"
    }
  }
}
